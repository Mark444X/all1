-- ฟังก์ชันตรวจจับว่าผู้เล่นนั่งรถอยู่หรือไม่
local function getActiveSpeed()
    local char = player.Character
    if char then
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if rootPart then
            -- ในเกม Jailbreak รถไม่ได้ใช้ระบบ SeatPart มาตรฐาน
            -- ต้องเช็คว่าตัวละครถูก Weld (เชื่อม) ติดกับสิ่งอื่นที่ไม่ใช่ตัวละครเราหรือไม่
            for _, part in pairs(rootPart:GetConnectedParts()) do
                if not part:IsDescendantOf(char) then
                    -- ถ้าเจอพาร์ทที่ไม่ได้อยู่ในโฟลเดอร์ตัวละครเรา แสดงว่าเรานั่งติดอยู่กับรถ
                    return flySpeedCar
                end
            end
        end
    end
    -- ถ้าไม่มีพาร์ทอื่นมาเชื่อมติดเลย = เดินปกติ
    return flySpeedChar
end

local function toggleFly()
    local character = player.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    if not isFlying then
        isFlying = true
        ToggleBtn.Text = "Fly Mode : ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        flyBV.Velocity = Vector3.new(0, 0, 0)
        flyBV.Parent = rootPart
        
        flyBG = Instance.new("BodyGyro")
        flyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        flyBG.P = 500000 
        flyBG.D = 5000
        
        -- จับหน้าหันให้ตรงแนวระนาบตอนกดเปิดบินครั้งแรกเสมอ
        local flatYaw = select(2, rootPart.CFrame:ToEulerAnglesYXZ())
        flyBG.CFrame = CFrame.Angles(0, flatYaw, 0)
        flyBG.Parent = rootPart
    else
        isFlying = false
        ToggleBtn.Text = "Fly Mode : OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        if flyBV then flyBV:Destroy() flyBV = nil end
        if flyBG then flyBG:Destroy() flyBG = nil end
        
        isHunting = false
        HuntBtn.Text = "🚀 Auto Hunt : OFF"
        HuntBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 200)
    end
end
ToggleBtn.MouseButton1Click:Connect(toggleFly)

local function getNearestPlayer()
    local char = player.Character
    if not char then return nil end
    local myRoot = char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end

    local nearestDist = math.huge
    local nearestPlr = nil

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
            if pRoot then
                local dist = (myRoot.Position - pRoot.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestPlr = p
                end
            end
        end
    end
    return nearestPlr
end

