local smoothAvoidDir = Vector3.new(0, 0, 0)

-----------------------------------------
-- 🔥 ระบบฟิสิกส์เหนือชั้น (God-Tier Smooth AI & Physics) 🔥
-----------------------------------------
RunService.RenderStepped:Connect(function(deltaTime)
    if isFlying and flyBV and flyBG then
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end
        
        -- ตรวจสอบความเร็วปัจจุบันแบบไดนามิก (บนรถ หรือ นอกรถ)
        local currentSpeed = getActiveSpeed()
        local moveDir = Vector3.new(0, 0, 0)
        local autoLookDir = Vector3.new(0, 0, 0)
        
        if isHunting and currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            -- [โหมด AI ล่าหัว ระดับเทพ (Smooth Lerp Avoidance)]
            local targetPos = currentTarget.Character.HumanoidRootPart.Position
            local dist = (targetPos - rootPart.Position).Magnitude
            local baseMoveDir = (targetPos - rootPart.Position).Unit
            
            -- [ระบบเบรกอัจฉริยะ (Auto Braking)] ลดความเร็วลงสมูทๆ เมื่อเข้าใกล้เป้าหมายในระยะ 500 เมตร
            if currentSpeed > 200 and dist < 500 then
                currentSpeed = 200 + ((currentSpeed - 200) * (dist / 500))
            end
            
            if dist < 8 then
                moveDir = Vector3.new(0, 0, 0)
                autoLookDir = Vector3.new(0, 0, 0)
            else
                local rayParams = RaycastParams.new()
                local ignoreList = {player.Character, currentTarget.Character}
                
                local jbVehicles = workspace:FindFirstChild("Vehicles")
                if jbVehicles then table.insert(ignoreList, jbVehicles) end
                for _, part in pairs(rootPart:GetConnectedParts()) do
                    if not part:IsDescendantOf(player.Character) then
                        local p = part
                        while p and p.Parent ~= workspace do
                            if p:IsA("Model") then table.insert(ignoreList, p) end
                            p = p.Parent
                        end
                    end
                end
                
                rayParams.FilterDescendantsInstances = ignoreList
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                rayParams.IgnoreWater = true
                
                local radarRange = math.max(150, currentSpeed * 0.4)
                -- ลดแคปซูลเรดาร์ให้เล็กลงเหลือ 4 เพื่อไม่ให้ไปเตะตาสิ่งกีดขวางที่ไม่ได้ขวางอยู่จริงๆ
                local hit = workspace:Spherecast(rootPart.Position, 4, baseMoveDir * radarRange, rayParams)
                
                local targetDodge = Vector3.new(0, 0, 0)
                if hit and dist > 1 then
                    -- เช็คความชันของสิ่งที่กำลังจะชน
                    if hit.Normal.Y < 0.5 then 
                        -- กำแพงตึกตั้งชัน: สแครชหลบข้าง + ปีนขึ้นฟ้า 
                        targetDodge = (baseMoveDir + hit.Normal * 1.5 + Vector3.new(0, 1.5, 0)).Unit
                    elseif hit.Normal.Y < 0.85 then
                        -- เนินเขา หรือหลังคาชันๆ: ค่อยๆ ลอยไต่ความสูงขึ้นไป
                        targetDodge = (baseMoveDir + Vector3.new(0, 0.8, 0)).Unit
                    else
                        -- [จุดแก้บัคลอยฟ้า] คือพื้นราบปกติ หรือพื้นถนน: ไม่ต้องหลบ! ให้พุ่งมุดลงไปหาเป้าหมายเลย!
                        targetDodge = baseMoveDir
                    end
                else
                    -- ทางสะดวก เล็งพุ่งตรงไปหาเป้าหมาย
                    targetDodge = baseMoveDir
                end
                
                -- **หัวใจของความสมูท**: ค่อยๆ ดัดทิศทาง (Lerp) ให้ไม่กระตุก ไม่ขูด หรือเด้งดึ๋ง
                if smoothAvoidDir.Magnitude < 0.001 then smoothAvoidDir = baseMoveDir end
                smoothAvoidDir = smoothAvoidDir:Lerp(targetDodge, 6 * deltaTime)
                moveDir = smoothAvoidDir.Unit
                
                local flatMove = Vector3.new(moveDir.X, 0, moveDir.Z)
                if flatMove.Magnitude > 0.001 then
                    autoLookDir = flatMove.Unit
                else
                    autoLookDir = Vector3.new(baseMoveDir.X, 0, baseMoveDir.Z)
                end
            end
            
            -- โหมด AI: หันหน้ารถไปตามทางที่พุ่งหนีตึก
            if autoLookDir.Magnitude > 0.001 then
                flyBG.CFrame = CFrame.new(rootPart.Position, rootPart.Position + autoLookDir.Unit)
            end
            
        else
            -- [โหมดบินปกติแมนนวล (ชิปล็อคเทียมครอบจักรวาล ทั้งรถทั้งคน)]
            smoothAvoidDir = Vector3.new(0, 0, 0) -- รีเซตค่าหลบหลีกตึก
            local camCFrame = camera.CFrame
            
            local ySensitivity = 0.4
            local softLook = Vector3.new(camCFrame.LookVector.X, camCFrame.LookVector.Y * ySensitivity, camCFrame.LookVector.Z)
            if softLook.Magnitude > 0.001 then softLook = softLook.Unit else softLook = Vector3.new(0,0,1) end
            
            local flatRight = Vector3.new(camCFrame.RightVector.X, 0, camCFrame.RightVector.Z)
            if flatRight.Magnitude > 0.001 then flatRight = flatRight.Unit else flatRight = Vector3.new(1,0,0) end
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + softLook end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - softLook end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - flatRight end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + flatRight end
            
            if currentSpeed == flySpeedCar then
                -- [ยานพาหนะ] ขึ้น/ลง ด้วย X และ Z
                if UserInputService:IsKeyDown(Enum.KeyCode.X) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.Z) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            else
                -- [ตัวเปล่า] ขึ้น/ลง ด้วย Space และ LeftControl
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
            end
            
            -- บังคับหันหน้าตามทิศกล้อง 100% ตลอดเวลา (Pseudo Shift-Lock ทั้งคนทั้งรถ)
            local flatLook = Vector3.new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z)
            if flatLook.Magnitude > 0.001 then
                -- อัปเดตเฉพาะตอนที่มีการกดเดิน เพื่อป้องกันอาการรถหมุนติ้วแข่งกับกล้องในเกมตอนที่ปล่อยเมาส์ยืนนิ่งๆ
                if moveDir.Magnitude > 0 then
                    flyBG.CFrame = CFrame.new(rootPart.Position, rootPart.Position + flatLook.Unit)
                end
            end
        end
        
        -- อัปเดตขับเคลื่อนฟิสิกส์
        if moveDir.Magnitude > 0 then 
            flyBV.Velocity = moveDir.Unit * currentSpeed
        else 
            flyBV.Velocity = Vector3.new(0,0,0) 
        end
    end
end)

